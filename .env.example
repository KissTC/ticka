# Configuración del Backend y Servidor
PORT=8082
ENV=development
API_URL=http://localhost:8082
ADMIN_TOKEN=cambia-esto-en-produccion

# Configuración de Base de Datos PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=ticka_user
DB_PASSWORD=ticka_secure_password
DB_NAME=ticka_db
DB_SSLMODE=disable

# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
FRONTEND_URL=http://localhost:3000

# Frontend (Next.js) — prefijo NEXT_PUBLIC_ para el browser
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_...

# Unsplash (galería externa de imágenes)
# Crea una app en https://unsplash.com/oauth/applications y copia el Access Key
UNSPLASH_ACCESS_KEY=tu_access_key_de_unsplash

# Credenciales de DigitalOcean Spaces (S3 Compatible)
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=nyc3
S3_ACCESS_KEY=TU_ACCESS_KEY
S3_SECRET_KEY=TU_SECRET_KEY
S3_BUCKET=ticka-spaces
S3_CDN_URL=https://ticka-spaces.nyc3.cdn.digitaloceanspaces.com
