# ============================================================
# Variables de entorno de PRODUCCIÓN — solo para el VPS
# Copia este archivo a ".env" en el VPS y llena los valores reales.
# NUNCA lo subas a git con valores reales.
#
# Uso en el VPS:
#   cp .env.production.example .env
#   nano .env   # llenar valores
#   docker compose -f docker-compose.prod.yml up -d --build
# ============================================================

# --- Dominio y URLs ---
FRONTEND_URL=https://ticka.dev
# Orígenes permitidos por CORS (separados por coma, sin espacios, sin slash final)
CORS_ORIGINS=https://ticka.dev,https://www.ticka.dev

# --- Admin ---
# Genera uno fuerte y único, ej: openssl rand -hex 32
ADMIN_TOKEN=cambia-esto-por-un-token-largo-y-aleatorio

# --- Base de Datos PostgreSQL ---
DB_USER=ticka_user
DB_PASSWORD=cambia-esto-por-una-contrasena-fuerte
DB_NAME=ticka_db

# --- Clerk Auth (instancia de PRODUCCIÓN, no test) ---
# Crear en https://dashboard.clerk.com — agregar ticka.dev como dominio permitido
CLERK_SECRET_KEY=sk_live_...

# --- Stripe (decide si lanzas en modo test o live) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# --- DigitalOcean Spaces (S3 compatible) ---
# Mismas credenciales que ya usas — no cambian entre dev y prod
S3_ENDPOINT=https://sfo3.digitaloceanspaces.com
S3_REGION=sfo3
S3_ACCESS_KEY=tu_access_key
S3_SECRET_KEY=tu_secret_key
S3_BUCKET=cp-rotom
S3_CDN_URL=https://cp-rotom.sfo3.digitaloceanspaces.com
